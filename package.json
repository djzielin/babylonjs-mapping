{
  "name": "babylonjs-mapping",
  "version": "1.1.43",
  "author": "David Zielinski <djzielin@gmail.com>",
  "license": "MIT",
  "description": "module to help display map content from OpenStreetMaps, Mapbox, and AGOL natively in Babylon.js",
  "main": "lib/index.js",
  "type": "module",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json",
    "./lib/*": "./lib/*.js",
    "./lib/core/*": "./lib/core/*.js",
    "./lib/raster/*": "./lib/raster/*.js",
    "./lib/buildings/*": "./lib/buildings/*.js",
    "./lib/terrain/*": "./lib/terrain/*.js",
    "./lib/shared/*": "./lib/shared/*.js"
  },
  "dependencies": {
    "@babylonjs/core": "^6.49.0",
    "@babylonjs/gui": "^6.49.0",
    "earcut": "^2.2.4"
  },
  "devDependencies": {
    "@types/earcut": "^2.1.4",
    "rimraf": "^5.0.10",
    "typescript": "~5.8.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --build tsconfig.npm.json",
    "clean": "rimraf ./lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djzielin/babylonjs-mapping.git"
  },
  "bugs": {
    "url": "https://github.com/djzielin/babylonjs-mapping/issues"
  },
  "keywords": [
    "babylonjs",
    "mapping",
    "openstreetmaps",
    "OSM",
    "mapbox"
  ],
  "homepage": "https://github.com/djzielin/babylonjs-mapping#readme",
  "files": [
    "lib/**/*",
    "src/**/*"
  ]
}
